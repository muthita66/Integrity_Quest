generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model action_types {
  type_id           Int                 @id @default(autoincrement())
  action_key        String              @unique @db.VarChar(50)
  action_name       String?             @db.VarChar(100)
  category          String?             @db.VarChar(50)
  logs_user_actions logs_user_actions[]
}

model departments {
  dept_id    Int       @id @default(autoincrement())
  dept_name  String    @db.VarChar(100)
  faculty_id Int
  faculties  faculties @relation(fields: [faculty_id], references: [faculty_id], onDelete: NoAction, onUpdate: NoAction, map: "dept_fk_faculty")
}

model faculties {
  faculty_id     Int            @id @default(autoincrement())
  faculty_name   String         @db.VarChar(100)
  group_id       Int
  departments    departments[]
  faculty_groups faculty_groups @relation(fields: [group_id], references: [group_id], onDelete: NoAction, onUpdate: NoAction, map: "faculty_pk_groups")
  majors         majors[]
}

model faculty_groups {
  group_id   Int         @id @default(autoincrement())
  group_name String      @db.VarChar(100)
  faculties  faculties[]
}

model feedback {
  feedback_id Int      @id
  user_id     Int
  unit_id     Int
  rating      Int
  comment     String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  units       units    @relation(fields: [unit_id], references: [unit_id], onDelete: NoAction, onUpdate: NoAction, map: "feedback_fk_unit")
  users       users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "feedback_fk_user")
}

model game_contents_mission {
  content_id     Int      @id(map: "game_contents_pkey") @default(autoincrement())
  mission_id     Int
  question       String
  correct_answer String
  options        Json
  missions       missions @relation(fields: [mission_id], references: [mission_id], onDelete: NoAction, onUpdate: NoAction, map: "game_mission_fk_mission")
}

model logs_user_actions {
  log_id       Int           @id @default(autoincrement())
  user_id      Int?
  type_id      Int?
  reference_id Int?
  description  String?
  time_spent   Int?
  created_at   DateTime?     @default(now()) @db.Timestamp(6)
  action_types action_types? @relation(fields: [type_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction)
  users        users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model majors {
  major_id   Int        @id @default(autoincrement())
  major_name String?    @db.VarChar(255)
  faculty_id Int?
  faculties  faculties? @relation(fields: [faculty_id], references: [faculty_id], onDelete: NoAction, onUpdate: NoAction, map: "major_fk_faculty")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model mission_rewards {
  mission_id Int
  reward_id  Int
  missions   missions @relation(fields: [mission_id], references: [mission_id], onDelete: NoAction, onUpdate: NoAction, map: "mission_fk")
  rewards    rewards  @relation(fields: [reward_id], references: [reward_id], onDelete: NoAction, onUpdate: NoAction, map: "reward_fk")

  @@ignore
}

model mission_types {
  type_id     Int        @id @default(autoincrement())
  type_name   String     @db.VarChar(255)
  description String?
  missions    missions[]
}

model missions {
  mission_id            Int                     @id @default(autoincrement())
  unit_id               Int
  type_id               Int
  level_number          Int
  mission_name          String                  @db.VarChar(255)
  is_active             Boolean
  game_contents_mission game_contents_mission[]
  mission_rewards       mission_rewards[]       @ignore
  mission_types         mission_types           @relation(fields: [type_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction, map: "mission_fk_type")
  units                 units                   @relation(fields: [unit_id], references: [unit_id], onDelete: NoAction, onUpdate: NoAction, map: "mission_fk_unit")
  user_missions         user_missions[]
}

model quizzes {
  quiz_id           Int                 @id @default(autoincrement())
  unit_id           Int?
  quiz_type         quiz_type_enum
  question_text     String
  max_score         Int?                @default(5)
  units             units?              @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade, onUpdate: NoAction)
  user_quiz_answers user_quiz_answers[]
}

model reward_types {
  type_id     Int      @id @default(autoincrement())
  type_name   String   @db.VarChar(100)
  description String?
  rewards     rewards?
}

model rewards {
  reward_id           Int                   @id @default(autoincrement())
  reward_name         String                @db.VarChar(255)
  reward_value        Int
  type_id             Int
  mission_rewards     mission_rewards[]     @ignore
  reward_types        reward_types          @relation(fields: [reward_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction, map: "reward_fk_reward_type")
  user_earned_rewards user_earned_rewards[] @ignore
}

model roles {
  role_id   Int     @id @default(autoincrement())
  role_name String  @db.VarChar(50)
  users     users[]
}

model students {
  student_id        Int       @id @default(autoincrement())
  user_id           Int
  first_name        String    @db.VarChar(255)
  last_name         String    @db.VarChar(255)
  gender            String    @db.VarChar(50)
  birth_year        Int
  entry_year        Int?
  major_id          Int?
  registration_date DateTime? @db.Date
  users             users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "student_fk-userID")
}

model teachers {
  teacher_id Int      @id @default(autoincrement())
  user_id    Int
  first_name String   @db.VarChar(255)
  last_name  String   @db.VarChar(255)
  gender     String   @db.VarChar(50)
  birth_date DateTime @db.Date
  dept_id    Int
  position   String   @db.VarChar(255)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "teacher_fk_userID")
}

model unit_contents {
  content_id          Int             @id @default(autoincrement())
  unit_id             Int
  title               String          @db.VarChar(100)
  description         String?
  order_number        Int
  parent_id           Int?
  units               units           @relation(fields: [unit_id], references: [unit_id], onDelete: NoAction, onUpdate: NoAction, map: "content_fk_unit")
  unit_contents       unit_contents?  @relation("unit_contentsTounit_contents", fields: [parent_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  other_unit_contents unit_contents[] @relation("unit_contentsTounit_contents")
}

model units {
  unit_id       Int             @id @default(autoincrement())
  name_th       String          @db.VarChar(100)
  name_en       String          @db.VarChar(100)
  order_number  Int
  is_active     Boolean
  description   String?
  created_at    DateTime        @db.Timestamptz(6)
  updated_at    DateTime?       @db.Timestamptz(6)
  feedback      feedback[]
  missions      missions[]
  quizzes       quizzes[]
  unit_contents unit_contents[]
  user_progress user_progress[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model user_earned_rewards {
  user_id   Int
  reward_id Int
  earned_at DateTime @db.Timestamptz(6)
  rewards   rewards  @relation(fields: [reward_id], references: [reward_id], onDelete: NoAction, onUpdate: NoAction, map: "reward_fk")
  users     users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_fk")

  @@ignore
}

model user_missions {
  user_id      Int
  mission_id   Int
  score        Int?      @default(0)
  is_completed Boolean?  @default(false)
  completed_at DateTime? @db.Timestamp(6)
  missions     missions  @relation(fields: [mission_id], references: [mission_id], onDelete: Cascade, onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, mission_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_progress {
  progress_id           Int       @id @default(autoincrement())
  user_id               Int
  unit_id               Int
  score                 Int?      @default(0)
  completion_percentage Int?      @default(0)
  is_locked             Boolean?  @default(true)
  last_accessed         DateTime? @default(now()) @db.Timestamp(6)
  units                 units     @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade, onUpdate: NoAction)
  users                 users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, unit_id])
}

model user_quiz_answers {
  answer_id   Int       @id @default(autoincrement())
  user_id     Int?
  quiz_id     Int?
  score_given Int?
  answered_at DateTime? @default(now()) @db.Timestamp(6)
  quizzes     quizzes?  @relation(fields: [quiz_id], references: [quiz_id], onDelete: NoAction, onUpdate: NoAction)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model user_stats {
  user_id         Int      @id @default(autoincrement())
  total_points    Int
  current_streak  Int
  highest_score   Int
  last_login_date DateTime @db.Date
  users           users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "stats_fk_userID")
}

model users {
  id                  Int                   @id @default(autoincrement())
  username            String                @db.VarChar(100)
  email               String                @db.VarChar(100)
  password            String                @db.VarChar(255)
  role_id             Int
  last_login          DateTime              @db.Date
  created_at          DateTime              @db.Timestamptz(6)
  feedback            feedback[]
  logs_user_actions   logs_user_actions[]
  students            students[]
  teachers            teachers[]
  user_earned_rewards user_earned_rewards[] @ignore
  user_missions       user_missions[]
  user_progress       user_progress[]
  user_quiz_answers   user_quiz_answers[]
  user_stats          user_stats?
  roles               roles                 @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction, map: "user_fk_roleID")
}

enum quiz_type_enum {
  pre_test
  post_test
}
